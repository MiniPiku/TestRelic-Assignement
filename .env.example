# Copy to ".env" (never commit ".env") and add your key.
TESTRELIC_API_KEY=your_key_here

# Optional — point uploads at a non-default API host.
# TESTRELIC_CLOUD_ENDPOINT=https://platform.testrelic.ai/api/v1

# Optional — staging credentials. If TESTRELIC_STAGE_API_KEY is set it is
# mirrored onto TESTRELIC_API_KEY for the test run, and the endpoint defaults
# to https://stage.testrelic.ai/api/v1 unless TESTRELIC_STAGE_CLOUD_ENDPOINT is set.
# TESTRELIC_STAGE_API_KEY=
# TESTRELIC_STAGE_CLOUD_ENDPOINT=
